# ── Sicherheit ────────────────────────────────────────────────────────────────
JWT_SECRET=hier-einen-langen-zufaelligen-string-einsetzen
JWT_EXPIRES_IN=8h
AUTO_LOGOUT_MINUTES=60

# ── Frontend-URL (für CORS) ───────────────────────────────────────────────────
# Auf welcher Adresse ist das Frontend erreichbar?
FRONTEND_URL=http://localhost:3000

# ── SelectLine ────────────────────────────────────────────────────────────────
SELECTLINE_API_URL=http://dein-selectline-server:port/api/v1
SELECTLINE_USERNAME=api_benutzer
SELECTLINE_PASSWORD=api_passwort
SELECTLINE_MANDANT=DEIN_MANDANT
SELECTLINE_IGNORE_SSL=false

# ── Web Push / VAPID (optional) ───────────────────────────────────────────────
# Generieren mit: cd backend && npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

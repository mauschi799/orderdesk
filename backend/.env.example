NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/orderdesk
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=8h
AUTO_LOGOUT_MINUTES=60

# SelectLine API (optional)
SELECTLINE_API_URL=http://your-selectline-server/api
SELECTLINE_API_KEY=your-selectline-api-key

# Web Push (VAPID) - generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@orderdesk.local

# SelectLine REST API credentials (replaces old API key approach)
SELECTLINE_API_URL=http://your-selectline-server:port/api/v1
SELECTLINE_USERNAME=api_user
SELECTLINE_PASSWORD=api_password
SELECTLINE_MANDANT=IHR_MANDANT
